create database gerenciadorSala;
use gerenciadorSala;
create table usuario(id int auto_increment primary key, name varchar(100), email varchar(255), senha varchar(255),previlegio varchar(100));
create table sala(id int auto_increment primary key,name varchar(100),bloco varchar(50),type varchar(100));
create table agendar_sala(id int auto_increment primary key,dia date,periodo varchar(100), idSala int, FOREIGN key(idSala) REFERENCES sala(id), idUser int, FOREIGN key(idUser) REFERENCES usuario(id));
create table recuperar_token(id int auto_increment primary key, idUser int not null, token varchar(64) not null, usado tinyint(1) default 0, foreign key (idUser) references usuario(id));