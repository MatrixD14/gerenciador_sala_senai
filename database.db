#drop database gerenciadorSala;
create database gerenciadorSala;
use gerenciadorSala;
create table usuario(
    id int auto_increment primary KEY,
    nome varchar(100) not null,
    email varchar(255) not null unique,
    senha varchar(255) not null,
    privilegio enum('admin','professor','aluno') not null
    );
create table sala(
    id int auto_increment primary key,
    nome varchar(100) not null,
    bloco varchar(50) not null,
    descricao varchar(100) not null,
    capacidade int,
    unique(nome,bloco)
    );
create table cursos(
     id int auto_increment primary key,
     nome varchar(200) not null,
     descricao varchar(255),
     unique(nome)
);
create table turmas(
     id int auto_increment primary key,
     nome varchar(200) not null,
     turno ENUM('manha', 'tarde', 'noite') not null,
     quantidade int not null,
     ano int not null,
     idCurso int not null,
     semestre TINYINT not null check (semestre IN (1,2)),
     periodo_curso TINYINT not null,
     foreign key(idCurso) references cursos(id),
     unique(nome, idCurso, ano, semestre)
);

create table agendar_sala(
    id int auto_increment primary key,
    hora_inicio time not null,
    hora_fim time not null,
    dia date not null,
    idUser int not null,
    idSala int not null,
    idTurma int not null,
    foreign key(idSala) references sala(id),
    foreign key(idUser) references usuario(id),
    foreign key(idTurma) references turmas(id)
    );


create table recuperacao_token(
    id int auto_increment primary key,
    idUser int not null,
    token varchar(255) not null,
    expiracao datetime not null,
    usado tinyint(1) default 0,
    created_at  datetime default current_timestamp,
    foreign key (idUser) references usuario(id) on delete cascade,
    INDEX idx_token (token)
    );
create table requisicoes_troca(
    id int auto_increment primary key,
    id_remetente int,
    id_agendamento_revindicado int,
    mensagem varchar(255),
    status enum('pendente', 'aprovado', 'recusado') DEFAULT 'pendente',
    data_envio datetime default current_timestamp,
    foreign key (id_remetente) references usuario(id),
    foreign key (id_agendamento_revindicado) references agendar_sala(id)
);