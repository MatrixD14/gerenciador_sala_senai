create database gerenciadorSala;
use gerenciadorSala;
create table usuario(
    id int auto_increment primary KEY,
    name varchar(100),
    email varchar(255),
    senha varchar(255),
    previlegio varchar(100)
    );
create table sala(
    id int auto_increment primary key,
    name varchar(100),
    bloco varchar(50),
    descricao varchar(100)
    );
create table agendar_sala(
    id int auto_increment primary key,
    dia date,
    periodo varchar(100),
    idUser int,
    idSala int,
    foreign key(idSala) references sala(id),
    foreign key(idUser) references usuario(id),
    unique (dia, periodo, idSala)
    );
create table recuperacao_token(
    id int auto_increment primary key,
    idUser int not null,
    token varchar(255) not null,
    expiracao datetime not null,
    usado tinyint(1) default 0,
    foreign key (idUser) references usuario(id) on delete cascade,
    INDEX idx_token (token)
    );
create table revindicados(
    id int auto_increment primary key,
    id_remetente int,
    id_agendamento_revindicado int,
    mensagem varchar(255),
    status varchar(50) default 'pendente',
    data_envio datetime default current_timestamp,
    foreign key (id_remetente) references usuario(id),
    foreign key (id_agendamento_revindicado) references agendar_sala(id)
);