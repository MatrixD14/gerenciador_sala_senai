use gerenciadorSala;
SET FOREIGN_KEY_CHECKS = 0;
DELETE FROM requisicoes_troca;
DELETE FROM recuperacao_token;
DELETE FROM agendar_sala;
DELETE FROM sala;
DELETE FROM usuario;
DELETE FROM turmas;
DELETE FROM cursos;
ALTER TABLE requisicoes_troca AUTO_INCREMENT = 1;
ALTER TABLE recuperacao_token AUTO_INCREMENT = 1;
ALTER TABLE agendar_sala AUTO_INCREMENT = 1;
ALTER TABLE sala AUTO_INCREMENT = 1;
ALTER TABLE usuario AUTO_INCREMENT = 1;
ALTER TABLE turmas AUTO_INCREMENT = 1;
ALTER TABLE cursos AUTO_INCREMENT = 1;
SET FOREIGN_KEY_CHECKS = 1;
INSERT INTO sala (nome, bloco, descricao,capacidade) 
SELECT CONCAT('Sala', n), 
CASE 
WHEN n % 5 = 0 THEN CONCAT('A-', (n%10)+1) 
WHEN n % 5 = 1 THEN CONCAT('B-', (n%10)+1) 
WHEN n % 5 = 2 THEN CONCAT('C-', (n%10)+1) 
WHEN n % 5 = 3 THEN CONCAT('D-', (n%10)+1)
WHEN n % 5 = 4 THEN CONCAT('E-', (n%10)+1)
ELSE CONCAT('F-', (n%10)+1) END, 
CASE 
WHEN n % 5 = 0 THEN 'Laboratorio de Quimica' 
WHEN n % 5 = 1 THEN 'Sala de Aula' 
WHEN n % 5 = 2 THEN 'Sala de Arte' 
WHEN n % 5 = 3 THEN 'Laboratorio de Informatica'
WHEN n % 5 = 4 THEN 'Laboratorio de Mecânica'
ELSE 'Quadra de Esporte' 
END,
FLOOR(rand() * 50)+10
FROM ( 
    SELECT (a.N + b.N * 10 + c.N * 100 + d.N * 1000 + e.N * 10000) + 1 as n
    FROM (
        SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a, 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b, 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) d,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) e
) numeros 
LIMIT 25000;

INSERT INTO usuario (nome, email, senha, privilegio)
SELECT 
CONCAT('Usuario', n),
CONCAT('usuario', n, '@email.com'),
'123456',
CASE 
    WHEN n % 3 = 0 THEN 'admin'
    WHEN n % 3 = 1 THEN 'professor'
    ELSE 'aluno'
END
FROM (
    SELECT (a.N + b.N * 10 + c.N * 100 + d.N * 1000 +e.N * 10000) + 1 as n
    FROM 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) d,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) e
) numeros
LIMIT 25000;

INSERT INTO cursos (nome,descricao)
SELECT 
CASE 
WHEN n % 5 = 0 THEN CONCAT('tecnico informatica',n)
WHEN n % 5 = 1 THEN CONCAT('informatica basica',n)
WHEN n % 5 = 2 THEN CONCAT('tecnico Mecânica',n)
WHEN n % 5 = 3 THEN CONCAT('tecnico de Mertalugia',n)
WHEN n % 5 = 4 THEN CONCAT('tecnico de Segurança',n)
ELSE CONCAT('Doutorado de infermagem',n)
END,
CASE 
WHEN n % 5 = 0 THEN 'curso' 
WHEN n % 5 = 1 THEN 'Sala de Aula' 
WHEN n % 5 = 2 THEN 'Sala de Arte' 
WHEN n % 5 = 3 THEN 'Laboratorio de Informatica'
WHEN n % 5 = 4 THEN 'Laboratorio de Mecânica'
ELSE 'Quadra de Esporte' 
END
FROM (
    SELECT (a.N + b.N * 10 + c.N * 100 + d.N * 1000 +e.N * 10000) + 1 as n
    FROM 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) d,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) e
) numeros
LIMIT 25000;

INSERT INTO turmas (nome, idCurso, turno, semestre, ano, quantidade,periodo_curso)
SELECT 
CONCAT('Turma',n),
((n - 1) % 25000) + 1,
CASE 
WHEN n % 3 = 1 THEN 'manha'
WHEN n % 3 = 2 THEN 'tarde'
ELSE 'noite'
END as turno,
CASE 
    WHEN n % 2 = 0 THEN 1
    ELSE 2
END,
2024 + (n % 3),
FLOOR(RAND() * 50)+10 as quantidade,
((n - 1) % 12) + 1
FROM (
    SELECT (a.N + b.N * 10 + c.N * 100 + d.N * 1000 + e.N * 10000) + 1 as n
    FROM
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) d,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) e
) numeros
LIMIT 25000;

INSERT INTO agendar_sala (dia, hora_inicio, hora_fim, idUser,idTurma, idSala)
SELECT 
DATE_ADD('2026-03-01', INTERVAL (FLOOR((n-1) / 3)) DAY),
CASE
WHEN n % 5 = 0 THEN '07:00'
WHEN n % 5 = 1 THEN '08:50'
WHEN n % 5 = 2 THEN '10:40'
WHEN n % 5 = 3 THEN '13:30'
ELSE '15:20'
END,
CASE 
WHEN n % 5 = 0 THEN '08:40'
WHEN n % 5 = 1 THEN '10:30'
WHEN n % 5 = 2 THEN '12:20'
WHEN n % 5 = 3 THEN '15:10'
ELSE '17:00'
END,
((n - 1) % 25000) + 1,
((n - 1) % 25000) + 1,
((n - 1) % 25000) + 1
FROM (
    SELECT (a.N + b.N * 10 + c.N * 100 + d.N * 1000 + e.N * 10000) + 1 as n
    FROM
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) d,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) e
) numeros
LIMIT 25000;