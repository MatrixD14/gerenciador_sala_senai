use gerenciadorSala;
DELETE FROM revindicados;
DELETE FROM recuperacao_token;
DELETE FROM agendar_sala;
DELETE FROM sala;
DELETE FROM usuario;
ALTER TABLE revindicados AUTO_INCREMENT = 1;
ALTER TABLE recuperacao_token AUTO_INCREMENT = 1;
ALTER TABLE agendar_sala AUTO_INCREMENT = 1;
ALTER TABLE sala AUTO_INCREMENT = 1;
ALTER TABLE usuario AUTO_INCREMENT = 1;
INSERT INTO sala (name, bloco, descricao) 
SELECT CONCAT('Sala ', n), 
CASE 
WHEN n % 5 = 0 THEN CONCAT('A-', (n%10)+1) 
WHEN n % 5 = 1 THEN CONCAT('B-', (n%10)+1) 
WHEN n % 5 = 2 THEN CONCAT('C-', (n%10)+1) 
WHEN n % 5 = 3 THEN CONCAT('D-', (n%10)+1) 
ELSE CONCAT('E-', (n%10)+1) END, 
CASE 
WHEN n % 5 = 0 THEN 'Laboratorio' 
WHEN n % 5 = 1 THEN 'Sala de Aula' 
WHEN n % 5 = 2 THEN 'Sala de Arte' 
WHEN n % 5 = 3 THEN 'Laboratorio de Informatica' 
ELSE 'Quadra de Esporte' 
END 
FROM ( 
    SELECT a.N + b.N * 10 + c.N * 100 + 1 n 
    FROM (
        SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a, 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b, 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c 
) numeros 
LIMIT 1000;
INSERT INTO usuario (name, email, senha, previlegio)
SELECT 
CONCAT('Usuario ', n),
CONCAT('usuario', n, '@email.com'),
'123456',
'normal'
FROM (
    SELECT a.N + b.N * 10 + c.N * 100 + d.N * 1000 + 1 n
    FROM 
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) d
) numeros
LIMIT 1000;
INSERT INTO agendar_sala (dia, periodo, idUser, idSala)
SELECT 
DATE_ADD('2026-03-01', INTERVAL (n % 30) DAY),
CASE 
WHEN n % 3 = 0 THEN 'manha'
WHEN n % 3 = 1 THEN 'tarde'
ELSE 'noite'
END,
(n % 400) + 1,
(n % 500) + 1
FROM (
    SELECT a.N + b.N * 10 + c.N * 100 + 1 n
    FROM
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) a,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) b,
    (SELECT 0 N UNION SELECT 1 UNION SELECT 2 UNION SELECT 3 UNION SELECT 4 UNION SELECT 5 UNION SELECT 6 UNION SELECT 7 UNION SELECT 8 UNION SELECT 9) c
) numeros
LIMIT 500;